# MCP API keys
LINEAR_API_KEY=
PRESTON_API_KEY=
GITHUB_ACCESS_TOKEN=

# Database
# Pool sizing + timeouts: bounded pool prevents slow Postgres from holding
# connections open indefinitely. connection_limit caps the pool size;
# connect_timeout caps how long Prisma waits when acquiring a connection.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/taq-u?connection_limit=5&connect_timeout=10
