{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:LINEAR_API_KEY}"
      }
    },
    "preston": {
      "type": "remote",
      "url": "https://api.preston.bot/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:PRESTON_API_KEY}"
      }
    }
  },
  "agent": {
    "effect-implement": {
      "description": "Helps implement Effect TypeScript patterns for services, layers, error handling, and resources",
      "mode": "subagent",
      "prompt": "{file:./.opencode/agents/effect-implement.md}"
    }
  }
}